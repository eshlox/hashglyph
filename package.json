{
  "name": "hashglyph",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "HashGlyph is a deterministic pixel-glyph logo system. Turn any name into a stable, hashed digital signature.",
  "license": "MIT",
  "author": "eshlox <eshlox@vertolabs.com>",
  "homepage": "https://hashglyph.eshlox.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/eshlox/hashglyph.git"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=26.3.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "build:all": "pnpm -r build",
    "build:web": "pnpm --filter @eshlox/hashglyph-core build && pnpm --filter @eshlox/hashglyph-web build",
    "dev:web": "pnpm --filter @eshlox/hashglyph-web dev",
    "cli": "node packages/cli/dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter @eshlox/hashglyph-web test:e2e",
    "typecheck": "tsc --build",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "brand:generate": "node scripts/generate-brand-assets.mjs",
    "brand:verify": "node scripts/generate-brand-assets.mjs && git diff --exit-code -- brand apps/web/public"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "25.9.3",
    "@vitest/coverage-v8": "4.1.9",
    "fast-check": "4.8.0",
    "jsdom": "27.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
