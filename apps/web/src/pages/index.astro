---
import { generateGlyph, HASHES, renderSvg, STYLES } from '@eshlox/hashglyph-core';
import Seo from '../components/Seo.astro';
import { CONCEPTS, HASH_NOTES, STYLE_NOTES } from '../lib/glossary';
import { SITE, SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from '../lib/site';
import '../styles/global.css';

const TITLE = SITE_TITLE;
const DESCRIPTION = SITE_DESCRIPTION;

const stripProlog = (svg: string) => svg.replace(/^<\?xml[^>]*\?>\s*/, '');

// The brand mark IS HashGlyph's own glyph (seed "hashglyph"), built at build time.
const brandMark = stripProlog(
  renderSvg(generateGlyph({ seed: 'hashglyph' }), { padding: 1, scale: 10 }),
);

// One sample digest per hash for the reference table. The style never changes the
// digest, so the hash is what makes each glyph unique.
const sampleRows = HASHES.map((h) => {
  const glyph = generateGlyph({ seed: 'hashglyph', hash: h.id });
  return { id: h.id, label: h.label, tier: h.tier, digest: glyph.digestHex.slice(0, 16) };
});

// Glossary rows, driven off the live registries so nothing drifts out of sync.
const hashGlossary = HASHES.map((h) => ({ id: h.id, label: h.label, tier: h.tier, ...HASH_NOTES[h.id] }));
const styleGlossary = STYLES.map((s) => ({ id: s.id, label: s.label, ...STYLE_NOTES[s.id] }));
---

<!doctype html>
<html lang="en">
  <head>
    <Seo title={TITLE} description={DESCRIPTION} site={SITE} />
  </head>
  <body>
    <header class="wrap topbar">
      <a class="brand" href="/" aria-label="HashGlyph home">
        <Fragment set:html={brandMark} />
        <span>HashGlyph</span>
      </a>
      <nav>
        <a href="#studio">Generate</a>
        <a href="#how">How it works</a>
        <a href="#algorithms">Algorithms</a>
        <a href="#glossary">Glossary</a>
        <a href="https://github.com/eshlox/hashglyph">GitHub</a>
      </nav>
    </header>

    <main>
      <section class="wrap hero">
        <span class="eyebrow">deterministic · BLAKE3 · 256-bit · reversible</span>
        <h1>A name in. <span class="grad">A glyph out.</span><br />Always the same one.</h1>
        <p class="lead">
          HashGlyph draws every bit of a 256-bit hash into a pixel grid, so each name gets its own
          glyph: unique, reproducible, and readable straight back into its digest. Same seed, same
          mark, forever.
        </p>
        <div class="slogans">
          <span>your name, compiled to pixels</span>
          <span>a hash you can hang on the wall</span>
          <span>git-versionable identity</span>
        </div>
      </section>

      <!-- ===================== STUDIO ===================== -->
      <section id="studio" class="wrap">
        <div class="studio">
          <!-- Controls -->
          <div class="card">
            <h2>Forge your glyph</h2>

            <div class="field">
              <label for="seed">Seed</label>
              <input id="seed" type="text" autocomplete="off" spellcheck="false" maxlength="64"
                placeholder="type any word…" />
              <p id="seed-error" class="error" hidden>Seed is empty after normalization. Try real characters.</p>
            </div>

            <div class="row">
              <div class="field">
                <label for="hash">Hash</label>
                <select id="hash">
                  {HASHES.map((h) => (
                    <option value={h.id}>{h.label}{h.tier === 'strong' ? '' : ` (${h.tier})`}</option>
                  ))}
                </select>
              </div>
              <div class="field">
                <label for="style">Style</label>
                <select id="style">
                  {STYLES.map((s) => <option value={s.id}>{s.label}</option>)}
                </select>
              </div>
            </div>

            <div class="row">
              <div class="field">
                <label for="fg">Pixel color</label>
                <div class="swatch"><input id="fg" type="color" /><span class="mono">fg</span></div>
              </div>
              <div class="field">
                <label for="bg">Background</label>
                <div class="swatch"><input id="bg" type="color" /><span class="mono">bg</span></div>
              </div>
              <div class="field">
                <label for="padding">Quiet zone</label>
                <input id="padding" type="range" min="0" max="4" step="1" />
              </div>
            </div>

            <div class="row" style="gap:18px;margin-bottom:6px">
              <label class="toggle"><input id="rounded" type="checkbox" /> Rounded pixels</label>
              <label class="toggle"><input id="transparent" type="checkbox" /> Transparent</label>
              <label class="toggle"><input id="qr-toggle" type="checkbox" /> QR mode</label>
            </div>
            <p id="contrast-warning" class="warn" hidden>⚠ Low contrast. This may be hard to read at favicon sizes.</p>

            <div class="btns">
              <button id="randomize" class="btn" type="button">🎲 Surprise me</button>
            </div>

            <div class="provenance">
              <div class="kv">
                <span>material</span><code id="material"></code>
                <span>digest (256-bit id)</span><code id="digest"></code>
              </div>
            </div>

            <div class="field" style="margin-top:14px">
              <label for="verify-seed">Verify a name against this glyph</label>
              <input id="verify-seed" type="text" autocomplete="off" spellcheck="false"
                maxlength="64" placeholder="type a name to check…" />
              <p id="verify-result" class="verify-result" data-state=""></p>
            </div>
          </div>

          <!-- Preview + actions -->
          <div class="card preview-stage">
            <div class="preview-frame" id="preview" role="img" aria-label="Live glyph preview"></div>

            <div class="btns" style="justify-content:center">
              <button id="dl-svg" class="btn primary" type="button">Download SVG</button>
              <span class="inline-select">
                <button id="dl-png" class="btn" type="button">PNG</button>
                <select id="png-size" aria-label="PNG size">
                  <option value="1024">1024</option>
                  <option value="512">512</option>
                  <option value="256" selected>256</option>
                  <option value="64">64</option>
                  <option value="32">32</option>
                  <option value="16">16</option>
                </select>
              </span>
              <button id="dl-ico" class="btn" type="button">favicon.ico</button>
              <button id="dl-zip" class="btn" type="button">⬇ All assets (.zip)</button>
              <button id="copy-svg" class="btn" type="button">Copy SVG</button>
            </div>

            <div style="width:100%">
              <label for="permalink" class="visually-hidden">Shareable permalink</label>
              <div class="permabar">
                <input id="permalink" type="text" readonly class="mono" />
                <button id="copy-link" class="btn" type="button">Copy link</button>
              </div>
            </div>

            <div id="qr-section" class="qr-section" hidden style="width:100%">
              <div class="field">
                <label for="qr-url">QR points to</label>
                <input id="qr-url" type="text" inputmode="url" autocomplete="off"
                  spellcheck="false" maxlength="512" placeholder="https://your-site.com" />
                <p id="qr-warning" class="warn" hidden>⚠ Long link. The code gets dense and may be harder to scan with the centered glyph.</p>
              </div>
              <div id="qr-preview" class="qr-preview"></div>
              <div class="btns" style="justify-content:center">
                <button id="dl-qr" class="btn" type="button">Download QR (PNG)</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Style picker -->
        <div class="card" style="margin-top:22px">
          <h3>Switch the render style</h3>
          <div id="matrix" class="matrix" aria-label="Available styles"></div>
        </div>
      </section>

      <!-- ===================== HOW IT WORKS ===================== -->
      <section id="how" class="block">
        <div class="wrap">
          <h2>How it works</h2>
          <p>
            The seed is normalized, prefixed with a frozen tag, and hashed to a 256-bit digest. Every
            bit of that digest is drawn into the grid: 256 pixels in mono, or 64 four-bit color cells.
            Nothing is thrown away, so the glyph is a lossless picture of the hash and reads straight
            back into its digest.
          </p>
          <div class="pipeline">your-name
  ↓ <b>normalize</b>            NFKC · trim · lowercase
your-name
  ↓ <b>domain separation</b>   hashglyph-v2|your-name
  ↓ <b>BLAKE3</b>              256-bit digest
  ↓ <b>encode</b>              every bit → one pixel
glyph  ⇄  digest
  ↓ <b>render</b>             SVG · PNG · ICO · QR</div>

          <div class="features">
            <div class="feature"><span class="ic">// deterministic</span><h3>Same in, same out</h3><p>One seed maps to exactly one glyph, forever. No timestamps, no randomness.</p></div>
            <div class="feature"><span class="ic">// unique</span><h3>No two names collide</h3><p>The whole 256-bit hash is on the wall. With a strong hash, two names sharing a glyph is computationally infeasible.</p></div>
            <div class="feature"><span class="ic">// reversible</span><h3>Decode &amp; verify</h3><p>Read a glyph back into its digest, or prove a name produced it. The original text stays private.</p></div>
            <div class="feature"><span class="ic">// portable</span><h3>Everywhere</h3><p>Crisp from 16px favicons to wall-sized SVG. Generation runs entirely in your browser.</p></div>
          </div>
        </div>
      </section>

      <!-- ===================== ALGORITHMS ===================== -->
      <section id="algorithms" class="block">
        <div class="wrap">
          <h2>Pick your hash</h2>
          <p>
            The hash decides the glyph; the style only decides how it is drawn. Choose from
            <strong>{HASHES.length} hashes</strong> rendered in <strong>{STYLES.length} styles</strong>.
            BLAKE3 is the default. The digest below is the seed <code class="mono">hashglyph</code> under
            each hash, so you can see how every one lands on a different glyph.
          </p>
          <table class="matrix-table">
            <thead><tr><th>Hash</th><th>id</th><th>tier</th><th>digest(hashglyph)</th></tr></thead>
            <tbody>
              {sampleRows.map((r) => (
                <tr><td>{r.label}</td><td class="mono">{r.id}</td><td class="mono">{r.tier}</td><td class="mono">{r.digest}…</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- ===================== GLOSSARY ===================== -->
      <section id="glossary" class="block">
        <div class="wrap">
          <h2>Plain-English glossary</h2>
          <p>
            Every option in the studio, explained in one line, with a link to the source so you can
            read more. The hash fixes your glyph; the style only changes how it is drawn.
          </p>

          <h3 class="glossary-head">Hashes</h3>
          <dl class="glossary">
            {hashGlossary.map((h) => (
              <div class="glossary-row">
                <dt><code class="mono">{h.id}</code> {h.label}{h.tier === 'strong' ? '' : ` (${h.tier})`}</dt>
                <dd>{h.blurb} <a href={h.href} rel="noopener" target="_blank">{h.source} ↗</a></dd>
              </div>
            ))}
          </dl>

          <h3 class="glossary-head">Render styles</h3>
          <dl class="glossary">
            {styleGlossary.map((s) => (
              <div class="glossary-row">
                <dt><code class="mono">{s.id}</code> {s.label}</dt>
                <dd>{s.blurb} <a href={s.href} rel="noopener" target="_blank">{s.source} ↗</a></dd>
              </div>
            ))}
          </dl>

          <h3 class="glossary-head">Concepts under the hood</h3>
          <dl class="glossary">
            {CONCEPTS.map((c) => (
              <div class="glossary-row">
                <dt>{c.term}</dt>
                <dd>{c.blurb} <a href={c.href} rel="noopener" target="_blank">{c.source} ↗</a></dd>
              </div>
            ))}
          </dl>
        </div>
      </section>
    </main>

    <footer class="wrap">
      <div class="footer-line">
        <span>HashGlyph · a deterministic pixel-glyph generator for everyone · made by <a href="https://eshlox.net">eshlox</a></span>
        <span class="mono">a name → a glyph, forever</span>
      </div>
      <nav class="social" aria-label="eshlox on social media">
        {
          SOCIAL_LINKS.map((link) => (
            <a href={link.href} rel="me noopener" target="_blank">
              {link.label}
            </a>
          ))
        }
      </nav>
    </footer>

    <script>
      import { initGenerator } from '../scripts/generator.js';
      const start = () => initGenerator();
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', start);
      else start();
    </script>
  </body>
</html>
